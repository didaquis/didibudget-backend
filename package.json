{
  "name": "didibudget-backend",
  "version": "1.0.4",
  "description": "didibudget-backend",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && cp -r src/public dist/public",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "clean": "rimraf logs dist",
    "prepare": "husky install"
  },
  "keywords": [
    "budget",
    "GraphQL",
    "Apollo",
    "Node.js",
    "MongoDB",
    "server"
  ],
  "author": "Dídac García (https://didaquis.github.io/)",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/bcrypt": "5.0.2",
    "@types/express": "4.17.25",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.12.4",
    "@types/serve-favicon": "2.5.7",
    "@types/uuid": "11.0.0",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "jsonfile": "6.2.0",
    "rimraf": "6.1.3",
    "tsc-alias": "1.8.17",
    "tsx": "4.21.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "vitest": "3.2.4"
  },
  "overrides": {
    "@types/express-serve-static-core": "4.17.43"
  },
  "dependencies": {
    "@graphql-tools/load-files": "6.6.1",
    "@graphql-tools/merge": "8.4.2",
    "apollo-server-express": "3.13.0",
    "bcrypt": "6.0.0",
    "cors": "2.8.5",
    "dotenv": "17.4.2",
    "express": "4.22.2",
    "graphql": "16.14.0",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "lodash.merge": "4.6.2",
    "log4js": "6.9.1",
    "mongoose": "8.24.0",
    "serve-favicon": "2.5.1",
    "uuid": "14.0.0"
  }
}